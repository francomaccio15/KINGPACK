# KINGPACK — Variables de entorno (template)
# Copiar a .env y completar con valores reales. NUNCA commitear .env

# ─── Base de datos ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kingpack_app:CHANGE_ME@localhost:5432/kingpack

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_super_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# ─── AFIP / ARCA ─────────────────────────────────────────────────────────────
AFIP_CUIT=20000000000          # CUIT del titular (sin guiones)
AFIP_ENV=homologacion          # homologacion | produccion
# Certificados AFIP — paths a los archivos .crt y .key
AFIP_CERT_PATH=./certs/afip.crt
AFIP_KEY_PATH=./certs/afip.key

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development           # development | production
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Backups (opcional) ──────────────────────────────────────────────────────
# B2_KEY_ID=
# B2_APP_KEY=
# B2_BUCKET=kingpack-backups
